# Client-side (Vite injects these into the browser bundle)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side (Vercel serverless functions — NEVER expose to client)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
OAUTH_JWT_SECRET=

# Optional
# FLUX_MCP_API_KEY=          # Legacy API key auth (fallback if OAuth unavailable)
# BASE_URL=                  # Override base URL (default: auto-detected from VERCEL_PROJECT_PRODUCTION_URL)
